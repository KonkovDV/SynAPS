{
  "$defs": {
    "AuxiliaryResource": {
      "description": "Shared resource (tool, fixture, operator, etc.).",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "domain_attributes": {
          "additionalProperties": true,
          "title": "Domain Attributes",
          "type": "object"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "pool_size": {
          "default": 1,
          "title": "Pool Size",
          "type": "integer"
        },
        "resource_type": {
          "title": "Resource Type",
          "type": "string"
        }
      },
      "required": [
        "code",
        "resource_type"
      ],
      "title": "AuxiliaryResource",
      "type": "object"
    },
    "Operation": {
      "description": "Single processing step within a work item.",
      "properties": {
        "base_duration_min": {
          "title": "Base Duration Min",
          "type": "integer"
        },
        "domain_attributes": {
          "additionalProperties": true,
          "title": "Domain Attributes",
          "type": "object"
        },
        "eligible_wc_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Eligible Wc Ids",
          "type": "array"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "order_id": {
          "format": "uuid",
          "title": "Order Id",
          "type": "string"
        },
        "predecessor_op_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Predecessor Op Id"
        },
        "seq_in_order": {
          "title": "Seq In Order",
          "type": "integer"
        },
        "state_id": {
          "format": "uuid",
          "title": "State Id",
          "type": "string"
        }
      },
      "required": [
        "order_id",
        "seq_in_order",
        "state_id",
        "base_duration_min"
      ],
      "title": "Operation",
      "type": "object"
    },
    "OperationAuxRequirement": {
      "description": "Operation \u2192 auxiliary resource requirement link.",
      "properties": {
        "aux_resource_id": {
          "format": "uuid",
          "title": "Aux Resource Id",
          "type": "string"
        },
        "operation_id": {
          "format": "uuid",
          "title": "Operation Id",
          "type": "string"
        },
        "quantity_needed": {
          "default": 1,
          "title": "Quantity Needed",
          "type": "integer"
        }
      },
      "required": [
        "operation_id",
        "aux_resource_id"
      ],
      "title": "OperationAuxRequirement",
      "type": "object"
    },
    "Order": {
      "description": "Work item or service request to schedule.",
      "properties": {
        "domain_attributes": {
          "additionalProperties": true,
          "title": "Domain Attributes",
          "type": "object"
        },
        "due_date": {
          "format": "date-time",
          "title": "Due Date",
          "type": "string"
        },
        "external_ref": {
          "title": "External Ref",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "priority": {
          "default": 500,
          "title": "Priority",
          "type": "integer"
        },
        "quantity": {
          "default": 1.0,
          "title": "Quantity",
          "type": "number"
        },
        "unit": {
          "default": "pcs",
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "external_ref",
        "due_date"
      ],
      "title": "Order",
      "type": "object"
    },
    "ProblemInstanceSlice": {
      "description": "Order-complete slice descriptor applied before ScheduleProblem validation.",
      "properties": {
        "max_operations": {
          "anyOf": [
            {
              "maximum": 200000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Max Operations"
        },
        "order_ids": {
          "anyOf": [
            {
              "items": {
                "format": "uuid",
                "type": "string"
              },
              "maxItems": 200000,
              "minItems": 1,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "title": "Order Ids"
        },
        "order_offset": {
          "minimum": 0,
          "title": "Order Offset",
          "type": "integer"
        }
      },
      "title": "ProblemInstanceSlice",
      "type": "object"
    },
    "RoutingContextContract": {
      "description": "JSON-serializable routing context for external callers.",
      "properties": {
        "exact_required": {
          "default": false,
          "title": "Exact Required",
          "type": "boolean"
        },
        "preferred_max_latency_s": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preferred Max Latency S"
        },
        "regime": {
          "$ref": "#/$defs/SolveRegime",
          "default": "nominal"
        }
      },
      "title": "RoutingContextContract",
      "type": "object"
    },
    "ScheduleProblem": {
      "description": "Complete input to any solver.",
      "properties": {
        "aux_requirements": {
          "items": {
            "$ref": "#/$defs/OperationAuxRequirement"
          },
          "maxItems": 400000,
          "title": "Aux Requirements",
          "type": "array"
        },
        "auxiliary_resources": {
          "items": {
            "$ref": "#/$defs/AuxiliaryResource"
          },
          "maxItems": 100000,
          "title": "Auxiliary Resources",
          "type": "array"
        },
        "operations": {
          "items": {
            "$ref": "#/$defs/Operation"
          },
          "maxItems": 200000,
          "title": "Operations",
          "type": "array"
        },
        "orders": {
          "items": {
            "$ref": "#/$defs/Order"
          },
          "maxItems": 200000,
          "title": "Orders",
          "type": "array"
        },
        "planning_horizon_end": {
          "format": "date-time",
          "title": "Planning Horizon End",
          "type": "string"
        },
        "planning_horizon_start": {
          "format": "date-time",
          "title": "Planning Horizon Start",
          "type": "string"
        },
        "setup_matrix": {
          "items": {
            "$ref": "#/$defs/SetupEntry"
          },
          "maxItems": 2000000,
          "title": "Setup Matrix",
          "type": "array"
        },
        "states": {
          "items": {
            "$ref": "#/$defs/State"
          },
          "maxItems": 10000,
          "title": "States",
          "type": "array"
        },
        "work_centers": {
          "items": {
            "$ref": "#/$defs/WorkCenter"
          },
          "maxItems": 10000,
          "title": "Work Centers",
          "type": "array"
        }
      },
      "required": [
        "states",
        "orders",
        "operations",
        "work_centers",
        "setup_matrix",
        "planning_horizon_start",
        "planning_horizon_end"
      ],
      "title": "ScheduleProblem",
      "type": "object"
    },
    "SetupEntry": {
      "description": "One cell in the SDST graph: changeover from state A to B on a work center.",
      "properties": {
        "domain_attributes": {
          "additionalProperties": true,
          "title": "Domain Attributes",
          "type": "object"
        },
        "energy_kwh": {
          "default": 0.0,
          "title": "Energy Kwh",
          "type": "number"
        },
        "from_state_id": {
          "format": "uuid",
          "title": "From State Id",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "material_loss": {
          "default": 0.0,
          "title": "Material Loss",
          "type": "number"
        },
        "setup_minutes": {
          "title": "Setup Minutes",
          "type": "integer"
        },
        "to_state_id": {
          "format": "uuid",
          "title": "To State Id",
          "type": "string"
        },
        "work_center_id": {
          "format": "uuid",
          "title": "Work Center Id",
          "type": "string"
        }
      },
      "required": [
        "work_center_id",
        "from_state_id",
        "to_state_id",
        "setup_minutes"
      ],
      "title": "SetupEntry",
      "type": "object"
    },
    "SolveOptions": {
      "description": "Stable solve-option subset exposed to external runtimes.",
      "properties": {
        "epsilon_constraints": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "integer"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Epsilon Constraints"
        },
        "material_loss_scale": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Material Loss Scale"
        },
        "max_iterations": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Iterations"
        },
        "num_workers": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Num Workers"
        },
        "objective_weights": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "integer"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Objective Weights"
        },
        "random_seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Random Seed"
        },
        "time_limit_s": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Time Limit S"
        }
      },
      "title": "SolveOptions",
      "type": "object"
    },
    "SolveRegime": {
      "description": "Operational contexts described in the solver portfolio docs.",
      "enum": [
        "nominal",
        "rush_order",
        "breakdown",
        "material_shortage",
        "interactive",
        "what_if"
      ],
      "title": "SolveRegime",
      "type": "string"
    },
    "State": {
      "description": "Product / process state used in SDST transitions.",
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "domain_attributes": {
          "additionalProperties": true,
          "title": "Domain Attributes",
          "type": "object"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "label": {
          "default": "",
          "title": "Label",
          "type": "string"
        }
      },
      "required": [
        "code"
      ],
      "title": "State",
      "type": "object"
    },
    "WorkCenter": {
      "description": "Execution resource, station, or processing unit.",
      "properties": {
        "capability_group": {
          "title": "Capability Group",
          "type": "string"
        },
        "code": {
          "title": "Code",
          "type": "string"
        },
        "domain_attributes": {
          "additionalProperties": true,
          "title": "Domain Attributes",
          "type": "object"
        },
        "id": {
          "format": "uuid",
          "title": "Id",
          "type": "string"
        },
        "max_parallel": {
          "default": 1,
          "title": "Max Parallel",
          "type": "integer"
        },
        "speed_factor": {
          "default": 1.0,
          "title": "Speed Factor",
          "type": "number"
        }
      },
      "required": [
        "code",
        "capability_group"
      ],
      "title": "WorkCenter",
      "type": "object"
    }
  },
  "description": "Canonical request contract for routed or explicit solve execution.",
  "oneOf": [
    {
      "required": [
        "problem"
      ]
    },
    {
      "required": [
        "problem_instance_ref"
      ]
    }
  ],
  "properties": {
    "context": {
      "$ref": "#/$defs/RoutingContextContract"
    },
    "contract_version": {
      "const": "2026-04-03",
      "default": "2026-04-03",
      "title": "Contract Version",
      "type": "string"
    },
    "problem": {
      "anyOf": [
        {
          "$ref": "#/$defs/ScheduleProblem"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "problem_instance_ref": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Problem Instance Ref"
    },
    "problem_slice": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProblemInstanceSlice"
        },
        {
          "type": "null"
        }
      ]
    },
    "request_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Request Id"
    },
    "solve_options": {
      "$ref": "#/$defs/SolveOptions"
    },
    "solver_config": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Solver Config"
    },
    "verify_feasibility": {
      "default": true,
      "title": "Verify Feasibility",
      "type": "boolean"
    }
  },
  "title": "SolveRequest",
  "type": "object"
}