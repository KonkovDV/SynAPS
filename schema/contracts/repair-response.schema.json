{
  "$defs": {
    "Assignment": {
      "description": "One operation \u2192 machine assignment in the result.",
      "properties": {
        "aux_resource_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Aux Resource Ids",
          "type": "array"
        },
        "end_time": {
          "format": "date-time",
          "title": "End Time",
          "type": "string"
        },
        "lane_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lane Id"
        },
        "operation_id": {
          "format": "uuid",
          "title": "Operation Id",
          "type": "string"
        },
        "setup_minutes": {
          "default": 0,
          "title": "Setup Minutes",
          "type": "integer"
        },
        "start_time": {
          "format": "date-time",
          "title": "Start Time",
          "type": "string"
        },
        "work_center_id": {
          "format": "uuid",
          "title": "Work Center Id",
          "type": "string"
        }
      },
      "required": [
        "operation_id",
        "work_center_id",
        "start_time",
        "end_time"
      ],
      "title": "Assignment",
      "type": "object"
    },
    "ObjectiveValues": {
      "description": "Multi-objective value vector.",
      "properties": {
        "makespan_minutes": {
          "default": 0.0,
          "title": "Makespan Minutes",
          "type": "number"
        },
        "total_material_loss": {
          "default": 0.0,
          "title": "Total Material Loss",
          "type": "number"
        },
        "total_setup_minutes": {
          "default": 0.0,
          "title": "Total Setup Minutes",
          "type": "number"
        },
        "total_tardiness_minutes": {
          "default": 0.0,
          "title": "Total Tardiness Minutes",
          "type": "number"
        },
        "weighted_sum": {
          "default": 0.0,
          "title": "Weighted Sum",
          "type": "number"
        }
      },
      "title": "ObjectiveValues",
      "type": "object"
    },
    "ScheduleResult": {
      "description": "Output of any solver.",
      "properties": {
        "assignments": {
          "items": {
            "$ref": "#/$defs/Assignment"
          },
          "title": "Assignments",
          "type": "array"
        },
        "duration_ms": {
          "default": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "error_category": {
          "$ref": "#/$defs/SolverErrorCategory",
          "default": "none"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "objective": {
          "$ref": "#/$defs/ObjectiveValues"
        },
        "random_seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Random Seed"
        },
        "solver_name": {
          "title": "Solver Name",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/SolverStatus"
        }
      },
      "required": [
        "solver_name",
        "status"
      ],
      "title": "ScheduleResult",
      "type": "object"
    },
    "SolverErrorCategory": {
      "description": "Structured error taxonomy for solver failures.\n\nEach category maps to a recovery hint that downstream systems can use\nto decide whether to retry, fall back, or escalate.",
      "enum": [
        "none",
        "timeout_partial",
        "timeout_no_solution",
        "infeasible_overconstrained",
        "infeasible_precedence_cycle",
        "infeasible_no_eligible_wc",
        "master_infeasible",
        "subproblem_infeasible",
        "constructive_failure",
        "internal_error"
      ],
      "title": "SolverErrorCategory",
      "type": "string"
    },
    "SolverStatus": {
      "enum": [
        "optimal",
        "feasible",
        "infeasible",
        "timeout",
        "error"
      ],
      "title": "SolverStatus",
      "type": "string"
    }
  },
  "description": "Canonical response contract for repair execution.",
  "properties": {
    "contract_version": {
      "const": "2026-04-03",
      "default": "2026-04-03",
      "title": "Contract Version",
      "type": "string"
    },
    "request_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Request Id"
    },
    "result": {
      "$ref": "#/$defs/ScheduleResult"
    }
  },
  "required": [
    "result"
  ],
  "title": "RepairResponse",
  "type": "object"
}